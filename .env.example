# Database Configuration (Aiven MySQL)
DB_PASSWORD=<your-aiven-password>

# JWT Authentication
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# Server Port (Render will set this automatically)
# SERVER_PORT=8080

# Note: For Render deployment:
# 1. Set DB_PASSWORD in Render Environment Variables
# 2. Set JWT_SECRET in Render Environment Variables
# 3. Render will automatically set PORT environment variable

# Note: For local development:
# Copy this file to .env and fill in actual values
# The application.properties uses ${VAR_NAME:default} syntax
