# Supabase PostgreSQL Configuration
SPRING_DATASOURCE_URL=jdbc:postgresql://db.<your-project-ref>.supabase.co:5432/postgres?sslmode=require
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=<your-supabase-db-password>

# JWT Authentication
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# Server Port (Render will set this automatically)
# SERVER_PORT=8080

# Note: For Render deployment:
# 1. Set SPRING_DATASOURCE_URL in Render Environment Variables
# 2. Set SPRING_DATASOURCE_USERNAME in Render Environment Variables
# 3. Set SPRING_DATASOURCE_PASSWORD in Render Environment Variables
# 4. Set JWT_SECRET in Render Environment Variables
# 5. Render will automatically set PORT environment variable

# Note: For local development:
# Copy this file to .env and fill in actual values
# The application.properties uses ${VAR_NAME:default} syntax
